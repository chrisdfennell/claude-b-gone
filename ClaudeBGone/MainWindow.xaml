<Window x:Class="ClaudeBGone.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Claude-B-Gone" Height="700" Width="950"
        MinHeight="500" MinWidth="700"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e2e">

    <Window.Resources>
        <!-- Dark theme colors -->
        <SolidColorBrush x:Key="BgPrimary" Color="#1e1e2e"/>
        <SolidColorBrush x:Key="BgSecondary" Color="#313244"/>
        <SolidColorBrush x:Key="BgTertiary" Color="#45475a"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#cdd6f4"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#a6adc8"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#89b4fa"/>
        <SolidColorBrush x:Key="AccentRed" Color="#f38ba8"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#a6e3a1"/>
        <SolidColorBrush x:Key="AccentYellow" Color="#f9e2af"/>
        <SolidColorBrush x:Key="BorderColor" Color="#585b70"/>

        <!-- Button style -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
            <Setter Property="Foreground" Value="#1e1e2e"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="{StaticResource AccentRed}"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="{StaticResource BgTertiary}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>

        <!-- TextBox style -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BgSecondary}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}"/>
        </Style>

        <!-- PasswordBox style -->
        <Style x:Key="DarkPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background" Value="{StaticResource BgSecondary}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Claude-B-Gone" FontSize="28" FontWeight="Bold"
                       Foreground="{StaticResource AccentBlue}"/>
            <TextBlock Text="Remove Claude Code co-author attributions from your git history"
                       FontSize="13" Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Mode selection and inputs -->
        <Border Grid.Row="1" Background="{StaticResource BgSecondary}" CornerRadius="8" Padding="16" Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Mode tabs -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                    <RadioButton x:Name="LocalModeRadio" Content="Local Repository" IsChecked="True"
                                 Foreground="{StaticResource TextPrimary}" FontSize="13" Margin="0,0,20,0"
                                 Checked="Mode_Changed"/>
                    <RadioButton x:Name="GitHubModeRadio" Content="GitHub Repository"
                                 Foreground="{StaticResource TextPrimary}" FontSize="13"
                                 Checked="Mode_Changed"/>
                </StackPanel>

                <!-- Local repo input -->
                <Grid x:Name="LocalPanel" Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Repo Path:" Foreground="{StaticResource TextSecondary}"
                               VerticalAlignment="Center" Margin="0,0,8,0" FontSize="13"/>
                    <TextBox x:Name="RepoPathBox" Grid.Column="1" Style="{StaticResource DarkTextBox}"
                             Text="" ToolTip="Path to local git repository"/>
                    <Button x:Name="BrowseButton" Grid.Column="2" Content="Browse..."
                            Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"
                            Click="Browse_Click"/>
                </Grid>

                <!-- GitHub repo input -->
                <Grid x:Name="GitHubPanel" Grid.Row="1" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Owner/Repo:" Foreground="{StaticResource TextSecondary}"
                               VerticalAlignment="Center" Margin="0,0,8,0" FontSize="13"/>
                    <TextBox x:Name="GitHubRepoBox" Grid.Column="1" Style="{StaticResource DarkTextBox}"
                             Text="" ToolTip="e.g. octocat/hello-world"/>
                    <TextBlock Grid.Row="1" Text="Token:" Foreground="{StaticResource TextSecondary}"
                               VerticalAlignment="Center" Margin="0,8,8,0" FontSize="13"/>
                    <PasswordBox x:Name="GitHubTokenBox" Grid.Row="1" Grid.Column="1"
                                 Style="{StaticResource DarkPasswordBox}" Margin="0,8,0,0"
                                 ToolTip="GitHub personal access token (optional, increases rate limit)"/>
                </Grid>

                <!-- Branch selector and author rewrite options -->
                <StackPanel Grid.Row="2" Margin="0,10,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Branch:" Foreground="{StaticResource TextSecondary}"
                                   VerticalAlignment="Center" Margin="0,0,8,0" FontSize="13"/>
                        <TextBox x:Name="BranchBox" Style="{StaticResource DarkTextBox}" Width="200"
                                 Text="" ToolTip="Leave empty for current/default branch"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <CheckBox x:Name="RewriteAuthorCheck" Content="Also rewrite commit author (removes Claude from Contributors)"
                                  Foreground="{StaticResource TextPrimary}" FontSize="13"
                                  IsChecked="False" Checked="RewriteAuthor_Changed" Unchecked="RewriteAuthor_Changed"/>
                    </StackPanel>
                    <StackPanel x:Name="AuthorPanel" Orientation="Horizontal" Margin="0,8,0,0" Visibility="Collapsed">
                        <TextBlock Text="Your Name:" Foreground="{StaticResource TextSecondary}"
                                   VerticalAlignment="Center" Margin="0,0,8,0" FontSize="13"/>
                        <TextBox x:Name="AuthorNameBox" Style="{StaticResource DarkTextBox}" Width="200"
                                 Text="" ToolTip="Name to replace Claude with"/>
                        <TextBlock Text="Your Email:" Foreground="{StaticResource TextSecondary}"
                                   VerticalAlignment="Center" Margin="16,0,8,0" FontSize="13"/>
                        <TextBox x:Name="AuthorEmailBox" Style="{StaticResource DarkTextBox}" Width="250"
                                 Text="" ToolTip="Email to replace Claude with"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Action buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
            <Button x:Name="ScanButton" Content="Scan for Claude Commits"
                    Style="{StaticResource PrimaryButton}" Click="Scan_Click"/>
            <Button x:Name="CleanButton" Content="Clean History" Margin="10,0,0,0"
                    Style="{StaticResource DangerButton}" Click="Clean_Click" IsEnabled="False"/>
            <Button x:Name="ForcePushButton" Content="Force Push" Margin="10,0,0,0"
                    Style="{StaticResource DangerButton}" Click="ForcePush_Click" IsEnabled="False"/>
            <Button x:Name="CloneCleanButton" Content="Clone, Clean &amp; Push" Margin="10,0,0,0"
                    Style="{StaticResource DangerButton}" Click="CloneAndClean_Click" IsEnabled="False"
                    Visibility="Collapsed"/>
            <TextBlock x:Name="StatusText" Text="" Foreground="{StaticResource AccentYellow}"
                       VerticalAlignment="Center" Margin="16,0,0,0" FontSize="13"/>
        </StackPanel>

        <!-- Results list -->
        <Border Grid.Row="3" Background="{StaticResource BgSecondary}" CornerRadius="8" Padding="2">
            <ListView x:Name="CommitList" Background="Transparent" BorderThickness="0"
                      Foreground="{StaticResource TextPrimary}" FontFamily="Cascadia Code,Consolas,Courier New"
                      FontSize="12" ScrollViewer.HorizontalScrollBarVisibility="Auto">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Hash" Width="80"
                                        DisplayMemberBinding="{Binding ShortHash}"/>
                        <GridViewColumn Header="Date" Width="100"
                                        DisplayMemberBinding="{Binding Date}"/>
                        <GridViewColumn Header="Subject" Width="350"
                                        DisplayMemberBinding="{Binding Subject}"/>
                        <GridViewColumn Header="Co-Author Line" Width="350"
                                        DisplayMemberBinding="{Binding CoAuthorLine}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <!-- Summary bar -->
        <Border Grid.Row="4" Background="{StaticResource BgSecondary}" CornerRadius="8"
                Padding="12,8" Margin="0,12,0,0">
            <TextBlock x:Name="SummaryText" Text="Ready. Enter a repository path or GitHub owner/repo and click Scan."
                       Foreground="{StaticResource TextSecondary}" FontSize="13"/>
        </Border>

        <!-- Log output -->
        <Border Grid.Row="5" Background="{StaticResource BgSecondary}" CornerRadius="8"
                Padding="2" Margin="0,12,0,0" MaxHeight="120">
            <TextBox x:Name="LogBox" Background="Transparent" Foreground="{StaticResource TextSecondary}"
                     BorderThickness="0" IsReadOnly="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto" FontFamily="Cascadia Code,Consolas,Courier New"
                     FontSize="11" Padding="8,6"/>
        </Border>
    </Grid>
</Window>
